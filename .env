# ========== LOGGING ==========
LOG_LEVEL=INFO
# Opções: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ========== CAMINHOS ==========
OUTPUT_DIR=output
TEMP_DIR=temp
PROGRESS_FILE=progresso.json
LOG_DIR=logs
CACHE_DIR=.cache

# ========== IA & MODELOS ==========
AI_TEMPERATURE=0.3
AI_MAX_RETRIES=2
AI_RETRY_DELAY=15

# ========== CACHE ==========
CACHE_ENABLED=True
CACHE_TTL_HOURS=24

# ========== BACKUP ==========
BACKUP_ENABLED=True
MAX_BACKUPS=5

# ========== VALIDAÇÃO ==========
MAX_FILE_SIZE_MB=50
